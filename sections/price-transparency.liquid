{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PriceTransparency-{{ section.id }} {
    {%- if section.settings.background_color != blank -%}
    background-color: {{ section.settings.background_color }};
    {%- endif -%}
    --pt-bg: rgb(var(--color-background));
    --pt-ink: rgb(var(--color-foreground));
    --pt-muted: rgba(var(--color-foreground), 0.6);
    --pt-line: rgba(var(--color-foreground), 0.12);
    --pt-accent: #8a6d40;
    --pt-accent-soft: #f8f2e8;
    --pt-bar-1: #6f5730;
    --pt-bar-2: #8a6d40;
    --pt-bar-3: #a98f63;
    --pt-bar-4: #bda37a;
    --pt-bar-5: #cdb994;
    --pt-bar-6: #ddd2bc;
    --pt-bar-7: #e8dfcd;
    --pt-bar-8: #f3ede1;
  }

  #PriceTransparency-{{ section.id }} * ,
  #PriceTransparency-{{ section.id }} *::before,
  #PriceTransparency-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #PriceTransparency-{{ section.id }} .pt-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  @media screen and (max-width: 899px) {
    #PriceTransparency-{{ section.id }} .pt-grid {
      grid-template-columns: 1fr;
    }
  }

  #PriceTransparency-{{ section.id }} .pt-copy .pt-eyebrow {
    font-size: 1.2rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pt-accent);
    margin: 0 0 1.4rem;
  }

  #PriceTransparency-{{ section.id }} .pt-copy h2 {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 3.4vw, 4.2rem);
    line-height: 1.12;
    font-weight: var(--font-heading-weight);
    letter-spacing: 0.02em;
    margin: 0 0 2.2rem;
    color: var(--pt-ink);
  }

  #PriceTransparency-{{ section.id }} .pt-copy p {
    font-size: clamp(1.5rem, 1.2vw, 1.7rem);
    line-height: 2.2rem;
    color: var(--pt-muted);
    margin: 0 0 1.6rem;
  }

  #PriceTransparency-{{ section.id }} .pt-copy p:last-child {
    margin-bottom: 0;
  }

  #PriceTransparency-{{ section.id }} .pt-chart {
    min-width: 0;
  }

  #PriceTransparency-{{ section.id }} .pt-chart-label {
    font-size: 1.2rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pt-muted);
    margin: 0 0 1.2rem;
  }

  #PriceTransparency-{{ section.id }} .pt-bar {
    display: block;
    width: 100%;
    height: 5.6rem;
    border-radius: 4px;
    overflow: hidden;
    white-space: nowrap;
    font-size: 0;
    line-height: 0;
    background: var(--pt-line);
  }

  #PriceTransparency-{{ section.id }} .pt-bar > div {
    display: inline-block;
    height: 100%;
    vertical-align: top;
  }

  #PriceTransparency-{{ section.id }} .pt-legend {
    list-style: none;
    margin: 1.8rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem 1.8rem;
  }

  #PriceTransparency-{{ section.id }} .pt-legend li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: 1.35rem;
    line-height: 1.45;
    color: var(--pt-ink);
  }

  #PriceTransparency-{{ section.id }} .pt-legend .pt-swatch {
    flex: 0 0 auto;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 3px;
    margin-top: 0.3rem;
  }

  #PriceTransparency-{{ section.id }} .pt-legend .pt-pct {
    display: block;
    color: var(--pt-muted);
    font-size: 1.25rem;
  }

  #PriceTransparency-{{ section.id }} .pt-icons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.4rem 0.8rem;
    margin: 0 0 4rem;
  }

  #PriceTransparency-{{ section.id }} .pt-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pt-muted);
    text-align: center;
    min-width: 0;
  }

  #PriceTransparency-{{ section.id }} .pt-icon .pt-icon-circle {
    width: 5.6rem;
    height: 5.6rem;
    border-radius: 50%;
    background: var(--pt-accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #PriceTransparency-{{ section.id }} .pt-icon svg {
    width: 2.6rem;
    height: 2.6rem;
    stroke: var(--pt-accent);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media screen and (max-width: 760px) {
    #PriceTransparency-{{ section.id }} .pt-icons {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.8rem 2.2rem;
    }
  }

  #PriceTransparency-{{ section.id }} .pt-compare {
    margin-top: 4.4rem;
  }

  #PriceTransparency-{{ section.id }} .pt-footnote {
    margin: 2rem 0 0;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--pt-muted);
  }
{%- endstyle -%}

<section
  id="PriceTransparency-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
  aria-labelledby="PriceTransparency-Title-{{ section.id }}"
>
  <div class="page-width section-{{ section.id }}-padding">
    <div class="pt-grid">

      <div class="pt-copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="pt-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 id="PriceTransparency-Title-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- if section.settings.paragraph_1 != blank -%}
          <p>{{ section.settings.paragraph_1 }}</p>
        {%- endif -%}
        {%- if section.settings.paragraph_2 != blank -%}
          <p>{{ section.settings.paragraph_2 }}</p>
        {%- endif -%}

        <div class="pt-icons" role="list" aria-label="Cost components">
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3 21l3.8-1L20 6.8 17.2 4 4 17.2z"/><path d="M14.5 6.5l3 3"/><path d="M6 14l1.5 1.5M9 11l1.5 1.5M12 8l1.5 1.5"/></svg>
            </span>
            Design
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3 8v9h13V8"/><ellipse cx="9.5" cy="8" rx="6.5" ry="3.2"/><path d="M16 17c2.8 0 5-1 5-2.5V9"/></svg>
            </span>
            Fabric
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M4 20 18 6"/><path d="M18 6c1.5-1.5 3-1.5 3 0s-1.5 3-3 3"/><circle cx="19" cy="7" r="0.4"/><path d="M4 20c3 0 5 1 8 0"/></svg>
            </span>
            Making
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 3h6a2 2 0 0 1 2 2v6l-9 9-8-8z"/><circle cx="16" cy="8" r="1.4"/></svg>
            </span>
            Trims
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><rect x="1.5" y="6" width="13" height="10"/><path d="M14.5 9.5h4L21.5 12.5v3.5h-7"/><circle cx="6" cy="18" r="1.8"/><circle cx="17.5" cy="18" r="1.8"/></svg>
            </span>
            Shipping
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M4 10v10h16V10"/><path d="M3 10 5 4h14l2 6"/><path d="M3 10c0 1.4 1.2 2.4 2.7 2.4S8.4 11.4 8.4 10c0 1.4 1.2 2.4 2.7 2.4s2.7-1 2.7-2.4c0 1.4 1.2 2.4 2.7 2.4S19.2 11.4 19.2 10"/><path d="M10 20v-5h4v5"/></svg>
            </span>
            Operations
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3 10v4l11 4V6z"/><path d="M14 7c3 1 5 2.8 5 5s-2 4-5 5"/><path d="M6 14.5V18a1.5 1.5 0 0 0 3 0v-2.4"/></svg>
            </span>
            Marketing
          </div>
          <div class="pt-icon" role="listitem">
            <span class="pt-icon-circle" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 20c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/><circle cx="17" cy="9" r="2.4"/><path d="M16 15.2c2.6.3 4.5 2.1 4.5 4.8"/></svg>
            </span>
            People
          </div>
        </div>
      </div>

      <div class="pt-chart">

        <p class="pt-chart-label">{{ section.settings.bar_label }}</p>
        <div
          class="pt-bar"
          role="img"
          aria-label="Price breakdown: design 11 percent, fabric 9 percent, making 27 percent, trims and packaging 4 percent, shipping and logistics 10 percent, operations and margin 16 percent, marketing 16 percent, people 7 percent"
        >
          <div style="width: 11%; background-color: var(--pt-bar-1);"></div>
          <div style="width: 9%; background-color: var(--pt-bar-2);"></div>
          <div style="width: 27%; background-color: var(--pt-bar-3);"></div>
          <div style="width: 4%; background-color: var(--pt-bar-4);"></div>
          <div style="width: 10%; background-color: var(--pt-bar-5);"></div>
          <div style="width: 16%; background-color: var(--pt-bar-6);"></div>
          <div style="width: 16%; background-color: var(--pt-bar-7);"></div>
          <div style="width: 7%; background-color: var(--pt-bar-8);"></div>
        </div>
        <ul class="pt-legend">
          <li><span class="pt-swatch" style="background: var(--pt-bar-1);"></span><span>Design<span class="pt-pct">In-house, Spain</span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-2);"></span><span>Fabric<span class="pt-pct">European mills</span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-3);"></span><span>Making<span class="pt-pct">Cut &amp; sew, Portugal ateliers</span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-4);"></span><span>Trims &amp; packaging<span class="pt-pct"></span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-5);"></span><span>Shipping &amp; logistics<span class="pt-pct"></span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-6);"></span><span>Operations &amp; margin<span class="pt-pct">What keeps us independent</span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-7);"></span><span>Marketing<span class="pt-pct">Ads to let you know about us</span></span></li>
          <li><span class="pt-swatch" style="background: var(--pt-bar-8);"></span><span>People<span class="pt-pct">To support our clients</span></span></li>
        </ul>

        {%- if section.settings.footnote != blank -%}
          <div class="pt-compare">
            <p class="pt-footnote">{{ section.settings.footnote }}</p>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Price transparency",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "info": "Opcional. Sobrescribe el fondo del esquema de color anterior."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Honest by design"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "What you actually pay for"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Párrafo 1",
      "default": "Every garment we make is designed and manufactured in Europe, and every euro of its price has a job. No guesswork, no hidden layers: this is how the price of one of our garments breaks down."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Párrafo 2",
      "default": "By selling directly to you, no wholesalers, no department stores, we skip the traditional retail markup and put that difference into fabric and construction instead."
    },
    {
      "type": "text",
      "id": "bar_label",
      "label": "Texto sobre la barra",
      "default": "Where each €100 goes"
    },
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Nota al pie",
      "default": "Figures shown are averages across our current collection. Middlemen, wholesale margins and department-store rents are the layers we removed, not the fabric."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Price transparency"
    }
  ]
}
{% endschema %}
