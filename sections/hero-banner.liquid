{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign v_pos = section.settings.desktop_content_position | split: '-' | first
  assign h_pos = section.settings.desktop_content_position | split: '-' | last

  case v_pos
    when 'top'
      assign desktop_align = 'flex-start'
    when 'bottom'
      assign desktop_align = 'flex-end'
    else
      assign desktop_align = 'center'
  endcase

  case h_pos
    when 'left'
      assign desktop_justify = 'flex-start'
    when 'right'
      assign desktop_justify = 'flex-end'
    else
      assign desktop_justify = 'center'
  endcase
-%}

<section
  id="Hero-{{ section.id }}"
  class="hero-banner hero-banner--{{ section.settings.image_height }} color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="hero-banner__media" aria-hidden="true">
    {%- if section.settings.media_type == 'video' and section.settings.video != null -%}
      {{
        section.settings.video
        | video_tag:
          image_size: '1920x',
          autoplay: section.settings.video_autoplay,
          loop: section.settings.video_loop,
          muted: true,
          controls: false,
          class: 'hero-banner__video'
      }}
    {%- elsif section.settings.image != blank -%}
      <picture class="hero-banner__picture">
        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{- section.settings.image_mobile | image_url: width: 750 }} 750w,
              {{ section.settings.image_mobile | image_url: width: 1500 }} 1500w
            "
          >
        {%- endif -%}
        {{
          section.settings.image
          | image_url: width: 3000
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '750, 1500, 2000, 3000',
            class: 'hero-banner__image',
            alt: section.settings.image.alt | escape
        }}
      </picture>
    {%- else -%}
      <div class="hero-banner__placeholder">
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg hero-banner__placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="hero-banner__overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity }}%;"></div>
  </div>

  <div class="hero-banner__content-wrapper page-width">
    <div class="hero-banner__content hero-banner__content--{{ section.settings.desktop_content_alignment }} hero-banner__content--mobile-{{ section.settings.mobile_content_alignment }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="hero-banner__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h1>
          {%- when 'text' -%}
            <div class="hero-banner__text" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div
              class="hero-banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} hero-banner__buttons--multiple{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #Hero-{{ section.id }} .hero-banner__content-wrapper {
    align-items: flex-end;
    justify-content: center;
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #Hero-{{ section.id }} .hero-banner__content-wrapper {
      align-items: {{ desktop_align }};
      justify-content: {{ desktop_justify }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero banner",
  "class": "section section--hero-banner",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "options": [
        { "value": "image", "label": "Imagen" },
        { "value": "video", "label": "Vídeo" }
      ],
      "default": "image",
      "label": "Tipo de contenido"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Imagen (mobile)",
      "info": "Opcional. Si se deja vacío se usa la imagen de desktop."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Vídeo",
      "info": "Se usa solo si el tipo de contenido es \"Vídeo\"."
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "default": true,
      "label": "Reproducir automáticamente"
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "default": true,
      "label": "Reproducir en bucle"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "small", "label": "Pequeña (50vh)" },
        { "value": "medium", "label": "Media (75vh)" },
        { "value": "large", "label": "Grande (90vh)" },
        { "value": "full", "label": "Pantalla completa (100vh)" }
      ],
      "default": "large",
      "label": "Altura"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 30,
      "label": "Opacidad de la capa oscura"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        { "value": "top-left", "label": "Arriba izquierda" },
        { "value": "top-center", "label": "Arriba centro" },
        { "value": "top-right", "label": "Arriba derecha" },
        { "value": "middle-left", "label": "Centro izquierda" },
        { "value": "middle-center", "label": "Centro centro" },
        { "value": "middle-right", "label": "Centro derecha" },
        { "value": "bottom-left", "label": "Abajo izquierda" },
        { "value": "bottom-center", "label": "Abajo centro" },
        { "value": "bottom-right", "label": "Abajo derecha" }
      ],
      "default": "bottom-center",
      "label": "Posición del contenido (desktop)"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center",
      "label": "Alineación del texto (desktop)"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center",
      "label": "Alineación del texto (mobile)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Título",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Nueva colección",
          "label": "Título"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Pequeño" },
            { "value": "h1", "label": "Medio" },
            { "value": "h0", "label": "Grande" },
            { "value": "hxl", "label": "Extra grande" },
            { "value": "hxxl", "label": "Máximo" }
          ],
          "default": "hxl",
          "label": "Tamaño del título"
        }
      ]
    },
    {
      "type": "text",
      "name": "Subtítulo",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Descubre las últimas piezas de la temporada.</p>",
          "label": "Subtítulo"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Botones",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Botón 1"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Comprar ahora",
          "label": "Texto del botón"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Enlace del botón"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_1",
          "default": false,
          "label": "Usar estilo secundario (outline)"
        },
        {
          "type": "header",
          "content": "Botón 2"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Texto del botón"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Enlace del botón"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "default": false,
          "label": "Usar estilo secundario (outline)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
